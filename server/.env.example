# Server
PORT=5000
JWT_SECRET=replace_with_your_jwt_secret

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=replace_with_your_firebase_project_id

# Email
SENDGRID_API_KEY=replace_with_your_sendgrid_api_key
FROM_EMAIL=replace_with_your_verified_sender_email

# SMS
TWILIO_ACCOUNT_SID=replace_with_your_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=replace_with_your_twilio_messaging_service_sid
